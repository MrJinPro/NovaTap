    <!-- Help / Tutorials Guides -->
    <string name="help_intro">Choose a guide to learn about modern touch automation mechanics:</string>
    <string name="guide_single_tap_title">Single Tap Guide</string>
    <string name="guide_single_tap_desc">Learn how to place a constant target clicker anywhere on the screen with milliseconds frequency precision.</string>
    <string name="guide_multi_tap_title">Multi Tap Guide</string>
    <string name="guide_multi_tap_desc">Need complex sequential loop clickers? Set up up to 20 nodes with delay timings in sequential or stochastic loop orders.</string>
    <string name="guide_area_tap_title">Area Tap Guide</string>
    <string name="guide_area_tap_desc">The safest clicker mechanism! Outline allowed (green) and blocked (red) zones. Our engine will randomize clicks inside valid spots, never crossing red-lines.</string>
    <string name="guide_swipe_title">Swipe &amp; Drag Guide</string>
    <string name="guide_swipe_desc">Simulate curved dragging gestures. Tweak duration to emulate slow drifts or quick swipes with Humanized Noise paths.</string>
    <string name="guide_scenarios_title">Scenario Automation Guide</string>
    <string name="guide_scenarios_desc">Combine single taps, wait states, swipe strokes, and area taps to form complete chains of interactions.</string>

